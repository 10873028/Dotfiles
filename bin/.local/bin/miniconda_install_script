#!/usr/bin/env bash

if [[ -d "miniconda.sh" ]]
then
    echo -e "\e[1;31merror: \e[0mfound directory \"miniconda.sh\"."
    exit 1
fi

if [[ ! -f "miniconda.sh" ]]
then
    echo -e "\e[1;34mDownloading...\e[0m"
    wget -c https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O miniconda.sh || echo -e "\e[1;31mFAILED\e[0m"
fi

if [[ -d "miniconda3" ]]
then
    echo -e "\e[1;31merror: \e[0mfound directory \"miniconda3\"."
    exit 1
fi

bash miniconda.sh -bp miniconda3 && echo -e "\e[1;32mDONE\e[0m" || echo -e "\e[1;31mFAILED\e[0m"
