#!/usr/bin/env bash
# script to create a script file and chmod to executable.

while [[ -z $SCRIPTLANG ]]
do
    read -r -p "Executive Language: " SCRIPTLANG
done

while [[ -z $FILENAME ]]
do
    read -r -p "Filename: " FILENAME
    if [[ -f $FILENAME ]] || [[ -d $FILENAME ]]
    then
        echo -e "\e[1;31merror: \e[0m$FILENAME already exists."
        FILENAME=""
    fi
done

echo -e "#!/usr/bin/env $SCRIPTLANG" > $FILENAME && chmod 700 $FILENAME && echo -e "\e[1;32mDONE\e[0m"

if [[ ! -z $EDITOR ]]
then
    $EDITOR $FILENAME || exit 1
fi
exit 0
